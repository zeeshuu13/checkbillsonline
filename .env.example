# Site
NEXT_PUBLIC_SITE_URL=https://checkbillsonline.com
NEXT_PUBLIC_SITE_NAME=Check Bills Online

# Unsplash API — free Access Key from https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Razorpay BBPS (India real-bill fetch) — provision from Razorpay dashboard after KYB
# https://razorpay.com/docs/bbps/billpay-android-app/api/
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_BBPS_BASE_URL=https://api.razorpay.com/v1

# Pakistan PITC — copied from MEPCO project. Increase budget when self-hosting.
PITC_INVOCATION_BUDGET_MS=30000

# AdSense (do not enable until approved)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_ENABLED=false

# Search Console verification (optional, also supported via /public/google*.html)
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
